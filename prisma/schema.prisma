generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Parcel {
  id          String   @id @default(cuid())
  apn         String?
  address     String?
  county      String
  state       String
  acreage     Float
  lat         Float?
  lon         Float?
  zoning      String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listings   Listing[]
  features   Features?
  fitScore   FitScore?
  deal       Deal?
  ownership  Ownership?

  @@unique([apn, county, state])
  @@index([state, county])
  @@index([acreage])
}

model Listing {
  id           String   @id @default(cuid())
  parcelId     String
  sourceId     String
  externalId   String?
  url          String
  title        String
  price        Float?
  pricePerAcre Float?
  status       String   @default("listed")
  photos       String?
  metadata     String?
  firstSeen    DateTime @default(now())
  lastSeen     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parcel Parcel @relation(fields: [parcelId], references: [id], onDelete: Cascade)

  @@unique([sourceId, externalId])
  @@index([parcelId])
  @@index([sourceId])
}

model Features {
  id             String  @id @default(cuid())
  parcelId       String  @unique
  landCoverMix   String?
  waterPresence  Boolean @default(false)
  waterFeatures  String?
  metroDistance   Float?
  nearestMetro   String?
  slopeStats     String?
  soilsQuality   Float?
  roadAccess     String?
  easements      String?
  powerDistance   Float?
  waterDistance   Float?
  sewerDistance   Float?
  fiberDistance   Float?
  gasDistance     Float?
  inFloodway     Boolean @default(false)
  floodZone      String?
  wetlandsPercent Float?
  elevation      Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  parcel Parcel @relation(fields: [parcelId], references: [id], onDelete: Cascade)
}

model FitScore {
  id             String   @id @default(cuid())
  parcelId       String   @unique
  overallScore   Int
  scoreBreakdown String
  topReasons     String
  autoFailed     Boolean  @default(false)
  autoFailReason String?
  calculatedAt   DateTime @default(now())

  parcel Parcel @relation(fields: [parcelId], references: [id], onDelete: Cascade)
}

model Deal {
  id         String   @id @default(cuid())
  parcelId   String   @unique
  stage      String   @default("new")
  priority   String   @default("medium")
  notes      String?
  nextAction String?
  nextDate   DateTime?
  assignee   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  parcel     Parcel     @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  activities Activity[]
}

model Activity {
  id        String   @id @default(cuid())
  dealId    String
  type      String
  content   String
  createdAt DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

model Ownership {
  id              String   @id @default(cuid())
  parcelId        String   @unique
  ownerName       String?
  ownerType       String?
  mailingAddress  String?
  acquisitionDate DateTime?
  acquisitionPrice Float?
  taxAssessment   Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parcel Parcel @relation(fields: [parcelId], references: [id], onDelete: Cascade)
}

model Source {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  baseUrl        String
  type           String
  enabled        Boolean  @default(true)
  crawlFrequency String   @default("weekly")
  rateLimitPerMin Int     @default(6)
  lastCrawl      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  scanSources ScanRunSource[]
}

model ScanRun {
  id             String   @id @default(cuid())
  status         String   @default("running")
  totalListings  Int      @default(0)
  newParcels     Int      @default(0)
  updatedParcels Int      @default(0)
  errors         Int      @default(0)
  startedAt      DateTime @default(now())
  completedAt    DateTime?

  sources ScanRunSource[]
}

model ScanRunSource {
  id        String   @id @default(cuid())
  scanRunId String
  sourceId  String
  status    String   @default("pending")
  listings  Int      @default(0)
  errors    Int      @default(0)
  errorLog  String?
  startedAt DateTime?
  completedAt DateTime?

  scanRun ScanRun @relation(fields: [scanRunId], references: [id], onDelete: Cascade)
  source  Source  @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([scanRunId])
  @@index([sourceId])
}

model SavedSearch {
  id        String   @id @default(cuid())
  name      String
  filters   String
  schedule  String   @default("manual")
  lastRun   DateTime?
  resultCount Int    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
